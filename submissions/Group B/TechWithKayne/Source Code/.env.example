# ─── Agora ────────────────────────────────────────────────────────────────────
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_certificate
AGORA_CUSTOMER_KEY=your_agora_customer_key
AGORA_CUSTOMER_SECRET=your_agora_customer_secret

# ─── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Frontend (Vite — prefix with VITE_)
# VITE_SUPABASE_URL=https://yourproject.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key

# ─── AI Provider ──────────────────────────────────────────────────────────────
# Options: ollama (local dev) | groq (free cloud) | bedrock (production)
TRIAGE_PROVIDER=ollama

# Ollama (local dev fallback)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# Groq (free tier, fast)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# AWS Bedrock (production — Claude Sonnet 4.6)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret

# ─── ElevenLabs TTS ───────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_VOICE_ID=your_voice_id

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
CORS_ORIGIN=http://localhost:5173,https://your-frontend.vercel.app
