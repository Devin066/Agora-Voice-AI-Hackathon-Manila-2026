    <mxCell id="33b" value="AKSYON text → audio/mpeg → browser AudioContext" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontColor=#772020;fontSize=8;" vertex="1" parent="17">
      <mxGeometry x="10" y="46" width="280" height="16" as="geometry" />
