    <!-- BHW App → BHW Triage Routes -->
    <mxCell id="e1" value="POST /triage&#xa;Bearer JWT (bhw)" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.35;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;endArrow=block;endFill=1;strokeColor=#4a90d9;fontColor=#4a90d9;fontSize=9;" edge="1" source="3" target="8" parent="1">
