# Copy to .env.local and add your keys

# Geoapify – location search (https://www.geoapify.com/)
NEXT_PUBLIC_GEOAPIFY_API_KEY=

# TomTom – traffic incidents in current map view (https://developer.tomtom.com/)
TOMTOM_API_KEY=

# --- LLM ---
# Option A – Local (unlimited): install Ollama (https://ollama.com), then: ollama run gemma3:4b
USE_LOCAL_LLM=false
LOCAL_LLM_URL=http://localhost:11434/v1/chat/completions
LOCAL_LLM_MODEL=gemma3:4b
# For voice with local LLM: expose your app with a tunnel (e.g. ngrok http 3000), then set:
# AGORA_LLM_PROXY_URL=https://YOUR-TUNNEL.ngrok.io/api/agora/llm-proxy
AGORA_LLM_PROXY_URL=

# Option B – OpenRouter (chat + voice when no tunnel). Gemma 3n free, 50 req/day (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Agora – voice/conversational AI (https://console.agora.io/)
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
# Same as AGORA_APP_ID; required in browser for voice channel join
NEXT_PUBLIC_AGORA_APP_ID=
# From Agora Console → Developer Toolkit → RESTful API → Add secret (download once)
AGORA_CUSTOMER_ID=
AGORA_CUSTOMER_SECRET=

# ElevenLabs – TTS for Agora voice (required for full voice mode). Get key at https://elevenlabs.io/
ELEVENLABS_API_KEY=
# Optional: voice ID (default: Rachel). Pick from https://elevenlabs.io/app/voice-lab (e.g. Bella, Josh) for a different sound.
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# Optional: model (default: eleven_flash_v2_5). eleven_multilingual_v2 can sound more natural but may be slower.
# ELEVENLABS_MODEL_ID=eleven_flash_v2_5
