# =====================================================
# GABAI APP - ENVIRONMENT VARIABLES EXAMPLE
# =====================================================

# Agora Credentials
VIDEO_APP_ID=your_agora_app_id
VIDEO_APP_CERTIFICATE=your_agora_app_certificate

# LLM Settings (Choose either Gemini or OpenAI)
# For Gemini (Recommended for gabAI):
VOICE_LLM_VENDOR=gemini
VOICE_LLM_API_KEY=your_gemini_api_key
VOICE_LLM_MODEL=gemini-2.0-flash
VOICE_LLM_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions

# For OpenAI:
# VIDEO_LLM_API_KEY=your_openai_api_key
# VIDEO_LLM_MODEL=gpt-4o-mini
# VIDEO_LLM_URL=https://api.openai.com/v1/chat/completions

# TTS Settings - MiniMax
VIDEO_TTS_VENDOR=minimax
VIDEO_TTS_KEY=your_minimax_api_key
VIDEO_MINIMAX_GROUP_ID=your_minimax_group_id
VIDEO_MINIMAX_VOICE_ID=Filipino_female_1_v1
VIDEO_MINIMAX_MODEL=speech-02-turbo
VIDEO_MINIMAX_URL=wss://api.minimax.io/ws/v1/t2a_v2
VIDEO_TTS_SAMPLE_RATE=24000

# ASR Settings
VIDEO_ASR_VENDOR=ares
VIDEO_ASR_LANGUAGE=en-US

# Avatar Settings (Choose either Anam or HeyGen)
# For Anam:
VIDEO_AVATAR_VENDOR=anam
VIDEO_AVATAR_API_KEY=your_anam_api_key
VIDEO_AVATAR_ID=your_anam_avatar_id

# For HeyGen:
# VIDEO_AVATAR_VENDOR=heygen
# VIDEO_AVATAR_API_KEY=your_heygen_api_key
# VIDEO_AVATAR_ID=your_heygen_avatar_id
# VIDEO_HEYGEN_QUALITY=high

# Agent Behavior & Timeouts
VIDEO_VAD_SILENCE_DURATION_MS=500
VIDEO_ENABLE_AIVAD=true
VIDEO_IDLE_TIMEOUT=120
VIDEO_MAX_HISTORY=32

# Prompts & Persona
VIDEO_DEFAULT_GREETING=Kamusta! Ako si gabAI, your personal AI study buddy para sa mga Filipino students. Overwhelmed ka ba sa deadlines mo, o may lesson ka bang hindi mo gets? Kausapin mo lang ako, nandito ako para sayo!
VIDEO_DEFAULT_PROMPT=You are gabAI, a warm and helpful Filipino AI study buddy designed for college and senior high students in the Philippines. Speak naturally in Taglish (mix of Filipino and English). Sound like a supportive ate or kuya — encouraging, patient, never condescending. Keep ALL responses short — 2 to 3 sentences only, this is a voice conversation not a text chat. Help students with: prioritizing tasks and deadlines when overwhelmed, explaining difficult lessons in simple conversational language, building quick cram plans before exams, quizzing students and giving encouraging feedback. Never give long paragraphs, always end with one clear actionable next step, use po occasionally to sound natural and Filipino.
VIDEO_DEFAULT_FAILURE_MESSAGE=Ay sorry, sandali lang ha — let me think about that again.

# Backend Port
PORT=3000
